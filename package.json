{
  "name": "prompt-dock",
  "version": "1.1.5",
  "private": true,
  "description": "A local desktop prompt manager with quick summon, tray access, search, tags, and clipboard copy.",
  "main": "src/main.js",
  "scripts": {
    "start": "node scripts/start-electron.js",
    "dev": "node scripts/start-electron.js",
    "build": "npm run dist",
    "dist": "electron-builder --mac dmg",
    "dist:mac": "electron-builder --mac dmg"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.local.promptdock",
    "productName": "Prompt Dock",
    "electronDist": "node_modules/electron/dist",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "!**/*.map",
      "!**/.DS_Store"
    ],
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": true,
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "title": "Prompt Dock",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
